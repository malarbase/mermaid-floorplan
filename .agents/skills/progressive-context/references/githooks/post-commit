#!/bin/sh
# progressive-context post-commit hook
# Checks if committed files affect any freshness-tracked context files.

GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$GIT_ROOT" ]; then
    exit 0
fi

# Locate the scripts directory (project-local first, then skill directories)
SCRIPT_DIR=""
for candidate in \
    "$GIT_ROOT/scripts" \
    "$HOME/.cursor/skills/progressive-context/scripts" \
    "$HOME/.claude/skills/progressive-context/scripts" \
    "$GIT_ROOT/.context-scripts"; do
    if [ -f "$candidate/context_check_watches.py" ]; then
        SCRIPT_DIR="$candidate"
        break
    fi
done

if [ -z "$SCRIPT_DIR" ]; then
    exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "[context] Warning: python3 not found, skipping freshness check"
    exit 0
fi

# Use -z for NUL-delimited output to handle filenames with spaces
git diff-tree --no-commit-id --name-only -r HEAD -z 2>/dev/null | xargs -0 python3 "$SCRIPT_DIR/context_check_watches.py"

exit 0
