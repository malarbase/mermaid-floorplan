# Template: Studio Apartment - FIXED variant
#
# Repaired studio addressing the critic findings on studio-rough.floorplan:
#   1. Kitchen now has a window on the exterior right wall (windowless_habitable fix).
#   2. Bath and Kitchen now share a wet wall (Bath.right = Kitchen.left) (wet_walls fix).
#   3. Bath no longer opens directly into LivingArea; it routes through Storage,
#      which acts as a small entry/closet buffer (bathroom_privacy fix).
#
# Footprint, room count, and overall studio character (single open Living
# without bedrooms) are preserved.

%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    area_unit: sqft
  }

  floor GroundFloor {
    # Storage doubles as a tiny entry vestibule in the upper-left corner.
    room Storage at (0,0) size (8 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] label "Storage"

    # Open studio living with windows on the exterior top + right walls.
    room LivingArea size (14 x 8) walls [top: window, right: window, bottom: solid, left: solid] right-of Storage align top label "Living"

    # Bath stacked under Storage, sharing its right wall with the Kitchen
    # (wet wall). Window on the exterior left wall preserved.
    room Bath size (8 x 12) walls [top: solid, right: solid, bottom: solid, left: window] below Storage align left label "Bath"

    # Kitchen now has an exterior right wall as a window (daylight) and
    # shares its left wall with Bath (wet plumbing run).
    room Kitchen size (14 x 12) walls [top: solid, right: window, bottom: solid, left: solid] right-of Bath align top label "Kitchen"
  }

  # Front door enters into Storage (acts as small foyer).
  connect Storage.top to outside door at 50%

  # Storage -> Living (main entry into the open studio space).
  connect Storage.right to LivingArea.left door at 50%

  # Living -> Kitchen (open studio circulation).
  connect LivingArea.bottom to Kitchen.top door at 50%

  # Bath routes through Storage rather than directly off Living (privacy).
  connect Storage.bottom to Bath.top door at 50%
