# Template: 2BR Apartment (~1000 sqft)
# Canonical two-bedroom floor plan organized around a horizontal hallway:
#
#   Row 1 (public):  Foyer | Living (open-plan) | Kitchen
#   Row 2 (hall):    Hall runs the full width
#   Row 3 (private): Bedroom 2 | Hall Bath | Master | Ensuite
#
# Anchored at Foyer; every other room is relative.
# 1 grid unit = 1 foot. Footprint 34 x 26 = 884 sqft net (target ~1000).
#
# Wall convention:
#   - Walls shared with another room are 'solid'; the 'connect ... door'
#     statements carve the door openings.
#   - 'open' is used only where two rooms are truly a single open-plan space
#     (here: foyer <-> living, living <-> kitchen).
#   - Exterior-facing walls are 'window' where natural light is wanted.

%%{version: 1.0}%%
floorplan

  floor GroundFloor {
    # Entry anchor. Door to outside, open to the living room on the right.
    room Foyer at (0,0) size (6 x 10) walls [top: solid, right: open, bottom: solid, left: solid] label "Entry"

    # Open-plan living room (open to foyer on the left, to kitchen on the right).
    room LivingRoom size (16 x 10) walls [top: window, right: open, bottom: solid, left: open] right-of Foyer align top label "Living"

    # Kitchen finishes the top row; window on the top, open wall to living.
    room Kitchen size (12 x 10) walls [top: window, right: solid, bottom: solid, left: open] right-of LivingRoom align top label "Kitchen"

    # Horizontal hallway below the public zone - serves every private room.
    room Hall size (34 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] below Foyer align left label "Hall"

    # Second bedroom - left side of the private row, window on the left.
    room KidsRoom size (10 x 12) walls [top: solid, right: solid, bottom: window, left: window] below Hall align left label "Bedroom 2"

    # Shared hall bathroom next to Bedroom 2.
    room Bath2 size (6 x 12) walls [top: solid, right: solid, bottom: solid, left: solid] right-of KidsRoom align top label "Bath"

    # Master bedroom next - window on the bottom.
    room MasterBedroom size (14 x 12) walls [top: solid, right: solid, bottom: window, left: solid] right-of Bath2 align top label "Master"

    # Master ensuite bathroom - plumbing wall shared with Bath2 (same side of the floor).
    room MasterBath size (6 x 12) walls [top: solid, right: window, bottom: solid, left: solid] right-of MasterBedroom align top label "Ensuite"
  }

  # Front door to outside
  connect Foyer.top to outside door at 50%

  # Foyer -> Hall
  connect Foyer.bottom to Hall.top door at 50%

  # Hall -> private rooms
  connect Hall.bottom to KidsRoom.top door at 15%
  connect Hall.bottom to Bath2.top door at 40%
  connect Hall.bottom to MasterBedroom.top door at 65%

  # Ensuite access from master bedroom
  connect MasterBedroom.right to MasterBath.left door at 30%
