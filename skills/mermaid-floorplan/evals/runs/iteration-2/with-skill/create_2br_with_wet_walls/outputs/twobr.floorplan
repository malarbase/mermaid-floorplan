# 2BR Apartment, ~1000 sqft.
# Public top row:   Foyer | LivingRoom (open plan) | Kitchen
# Middle row:       Hall (runs from Foyer) | HallBath (under Kitchen)
# Private bottom:   Bedroom 2 | Master | Ensuite
#
# Wet/plumbing wall: Kitchen.bottom and HallBath.top share the same
# interior wall (both x=24..36 at y=10), so kitchen sink/dishwasher
# stack vertically with the hall bath plumbing.
#
# Bedroom 2 has two exterior windows (left + bottom);
# Master has a window on the bottom exterior wall.
#
# 1 grid unit = 1 ft. Footprint 36 x 28 = 1008 sqft.

%%{version: 1.0}%%
floorplan

  floor GroundFloor {
    # Anchor: entry foyer at top-left.
    room Foyer at (0,0) size (6 x 10) walls [top: solid, right: open, bottom: solid, left: solid] label "Entry"

    # Open-plan living room (open to foyer on the left, kitchen on the right).
    room LivingRoom size (18 x 10) walls [top: window, right: open, bottom: solid, left: open] right-of Foyer align top label "Living"

    # Kitchen: top window, opens to living, bottom is the plumbing wall.
    room Kitchen size (12 x 10) walls [top: window, right: solid, bottom: solid, left: open] right-of LivingRoom align top label "Kitchen"

    # Horizontal hallway from foyer to bedrooms (does not run under the kitchen).
    room Hall size (24 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] below Foyer align left label "Hall"

    # Hall bath stacks directly under the kitchen -> shared wet/plumbing wall.
    room HallBath size (12 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] right-of Hall align top label "Hall Bath"

    # Bedroom 2 - private row, windows on left + bottom (exterior).
    room Bedroom2 size (12 x 14) walls [top: solid, right: solid, bottom: window, left: window] below Hall align left label "Bedroom 2"

    # Master bedroom - center of private row, window on bottom (exterior).
    room MasterBedroom size (14 x 14) walls [top: solid, right: solid, bottom: window, left: solid] right-of Bedroom2 align top label "Master"

    # Master ensuite - right side, window on right exterior wall.
    room MasterBath size (10 x 14) walls [top: solid, right: window, bottom: solid, left: solid] right-of MasterBedroom align top label "Ensuite"
  }

  # Front door (entry)
  connect Foyer.top to outside door at 50%

  # Foyer -> hallway
  connect Foyer.bottom to Hall.top door at 50%

  # Hallway -> private rooms
  connect Hall.bottom to Bedroom2.top door at 25%
  connect Hall.bottom to MasterBedroom.top door at 70%

  # Hallway -> hall bathroom
  connect Hall.right to HallBath.left door at 50%

  # Master bedroom -> ensuite
  connect MasterBedroom.right to MasterBath.left door at 30%
