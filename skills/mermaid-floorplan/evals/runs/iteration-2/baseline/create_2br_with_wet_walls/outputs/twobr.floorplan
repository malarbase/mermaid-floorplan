%%{version: 1.0}%%
floorplan
  # 2-Bedroom apartment, ~1000 sqft total.
  # Kitchen (18..28) and Bathroom (28..36) share east-west plumbing wall at x=28.
  # Both bedrooms have exterior windows.

  floor MainFloor {
    room LivingRoom at (0,0) size (18 x 14) walls [top: window, right: solid, bottom: solid, left: door] label "Living Room"

    room Kitchen at (18,0) size (10 x 9) walls [top: window, right: solid, bottom: solid, left: solid] label "Kitchen"

    room Bathroom at (28,0) size (8 x 9) walls [top: solid, right: solid, bottom: solid, left: solid] label "Bathroom"

    room Hallway at (18,9) size (18 x 5) walls [top: solid, right: solid, bottom: solid, left: solid] label "Hallway"

    room MasterBR at (0,14) size (14 x 14) walls [top: solid, right: solid, bottom: window, left: window] label "Master Bedroom"

    room Bedroom2 at (14,14) size (22 x 14) walls [top: solid, right: solid, bottom: window, left: solid] label "Bedroom 2"
  }

  connect LivingRoom.right to Kitchen.left door at 50%
  connect LivingRoom.right to Hallway.left door at 90%
  connect LivingRoom.bottom to MasterBR.top door at 25%
  connect Hallway.top to Bathroom.bottom door at 70%
  connect Hallway.bottom to Bedroom2.top door at 30%
