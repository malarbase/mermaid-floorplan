%%{version: 1.0}%%
floorplan
  config { wall_thickness: 0.25 }

  floor Studio {
    # Total: 480 sqft (40 + 56 + 64 + 320)
    room Vestibule at (0,0) size (5 x 8) walls [top: door, right: solid, bottom: solid, left: solid] label "Entry Vestibule"
    room Bathroom at (5,0) size (7 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] label "Bathroom"
    room Kitchen at (12,0) size (8 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] label "Kitchen"
    room SleepingArea at (0,8) size (20 x 16) walls [top: solid, right: solid, bottom: solid, left: solid] label "Sleeping / Living"
  }

  connect Vestibule.top to outside door at 50%
  connect Vestibule.right to Bathroom.left door at 50%
  connect Vestibule.bottom to SleepingArea.top door at 50%
  connect Kitchen.bottom to SleepingArea.top door at 80%
