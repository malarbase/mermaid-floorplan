%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    wall_thickness: 0.5
  }

  floor Main {
    # ============================================================
    # Top row: public/wet rooms (height 12)
    # ============================================================
    room Foyer at (0, 0) size (8 x 12)
      walls [top: solid, right: solid, bottom: solid, left: solid]
      label "Foyer"

    room Living at (8, 0) size (16 x 12)
      walls [top: window, right: solid, bottom: solid, left: solid]
      label "Living"

    room Dining at (24, 0) size (12 x 12)
      walls [top: window, right: solid, bottom: solid, left: solid]
      label "Dining"

    room Kitchen at (36, 0) size (14 x 12)
      walls [top: window, right: solid, bottom: solid, left: solid]
      label "Kitchen"

    # ============================================================
    # Hall corridor (full width, height 4)
    # ============================================================
    room Hall at (0, 12) size (50 x 4)
      walls [top: solid, right: solid, bottom: solid, left: solid]
      label "Hall"

    # ============================================================
    # Bottom row: bedrooms / baths (height 16)
    # ============================================================
    room Bedroom2 at (0, 16) size (12 x 16)
      walls [top: solid, right: solid, bottom: window, left: solid]
      label "Bedroom 2"

    room Bath2 at (12, 16) size (8 x 16)
      walls [top: solid, right: solid, bottom: solid, left: solid]
      label "Hall Bath"

    room Bedroom3 at (20, 16) size (12 x 16)
      walls [top: solid, right: solid, bottom: window, left: solid]
      label "Bedroom 3"

    room Master at (32, 16) size (12 x 16)
      walls [top: solid, right: solid, bottom: window, left: solid]
      label "Master"

    room MasterBath at (44, 16) size (6 x 16)
      walls [top: solid, right: solid, bottom: solid, left: solid]
      label "Ensuite"
  }

  # ============================================================
  # Connections - doors between hallway and rooms
  # ============================================================

  # Top row to Hall (positions chosen to be unique on Hall.top, ~10%+ apart)
  connect Foyer.bottom to Hall.top door at 8%
  connect Living.bottom to Hall.top door at 32%
  connect Dining.bottom to Hall.top door at 60%
  connect Kitchen.bottom to Hall.top door at 86%

  # Bottom row to Hall (positions chosen to be unique on Hall.bottom)
  connect Bedroom2.top to Hall.bottom door at 12%
  connect Bath2.top to Hall.bottom door at 32%
  connect Bedroom3.top to Hall.bottom door at 52%
  connect Master.top to Hall.bottom door at 76%

  # Master suite internal door
  connect Master.right to MasterBath.left door at 50%

  # Hall external door (left side)
  connect Hall.left to outside door at 50%
