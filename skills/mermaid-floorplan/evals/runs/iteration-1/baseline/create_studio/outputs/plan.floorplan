# 480 sqft studio apartment
# Layout (in feet):
#   Entry Vestibule   4 x  5 =  20 sqft
#   Bathroom          4 x  7 =  28 sqft
#   Kitchen           4 x  8 =  32 sqft
#   Sleeping/Living  20 x 20 = 400 sqft
#   ----------------------------------
#   Total                     480 sqft

%%{version: 1.0}%%
floorplan
  config { default_unit: ft, wall_thickness: 0.25 }

  floor Studio {
    # Anchor: Entry vestibule (top-left)
    room Entry at (0,0) size (4 x 5) walls [top: solid, right: solid, bottom: solid, left: solid] label "Entry"

    # Bathroom directly below the entry vestibule
    room Bathroom size (4 x 7) walls [top: solid, right: solid, bottom: solid, left: solid] below Entry label "Bathroom"

    # Kitchen below the bathroom, against the left wall
    room Kitchen size (4 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] below Bathroom label "Kitchen"

    # Open sleeping/living area to the right of the entry, spanning the full height
    room Sleeping at (4,0) size (20 x 20) walls [top: window, right: solid, bottom: window, left: solid] label "Sleeping / Living"
  }

  # Front door from outside into the entry vestibule
  connect Entry.top to outside door at 50%

  # Entry opens into the main living/sleeping area
  connect Entry.right to Sleeping.left door at 50%

  # Bathroom door into the main living area
  connect Bathroom.right to Sleeping.left door at 30%

  # Kitchen opens into the main living area (open pass-through)
  connect Kitchen.right to Sleeping.left double-door at 70%
