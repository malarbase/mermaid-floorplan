# Studio Apartment (~480 sqft)
# Single-volume living/sleep with a tucked kitchen, bath, and entry vestibule.
# Wet rooms (Kitchen + Bath) stack on the left so plumbing shares a wet wall.
# Footprint: 24 x 20 = 480 sqft (Kitchen 80 + Bath 70 + Entry 50 + LivingSleep 280).
#
#   Col 1: Kitchen (top), Bath (middle), Entry (bottom)
#   Col 2: LivingSleep (full height)
#
# Anchored at Kitchen. 1 grid unit = 1 foot.

%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    area_unit: sqft
  }

  floor GroundFloor {
    # Kitchen anchors the top-left corner. Cabinetry on solid walls; window over the sink.
    room Kitchen at (0,0) size (10 x 8) walls [top: window, right: solid, bottom: solid, left: solid] label "Kitchen"

    # Bath stacked under Kitchen so plumbing shares a wet wall.
    room Bath size (10 x 7) walls [top: solid, right: solid, bottom: solid, left: window] below Kitchen align left label "Bath"

    # Entry vestibule below the Bath; front door enters from the corridor side.
    room Entry size (10 x 5) walls [top: solid, right: solid, bottom: solid, left: solid] below Bath align left label "Entry Vestibule"

    # Open-plan living + sleeping volume; full-height right column with windows on three exterior walls.
    room LivingSleep size (14 x 20) walls [top: window, right: window, bottom: window, left: solid] right-of Kitchen align top label "Living / Sleep"
  }

  # Front door enters through the vestibule's corridor-side wall.
  connect Entry.bottom to outside door at 50%

  # Open-plan kitchen to living (wide pass-through).
  # Positioned high on LivingSleep.left because Kitchen sits in the upper third.
  connect Kitchen.right to LivingSleep.left opening at 20% size (6ft x full)

  # Bath access from the living/sleep area; bath is in the middle band.
  connect Bath.right to LivingSleep.left door at 55%

  # Vestibule opens into the main living/sleep volume; entry is at the bottom band.
  connect Entry.right to LivingSleep.left opening at 85% size (4ft x full)
