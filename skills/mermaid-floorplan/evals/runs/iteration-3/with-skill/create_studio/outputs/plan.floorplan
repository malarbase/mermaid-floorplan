# Studio480 — 480 sqft studio apartment
# Footprint 24 ft x 20 ft = 480 sqft. Wet rooms (Kitchen + Bath) share
# a vertical wall in the top strip; Vestibule sits in the top-left
# corner with the front door. SleepingArea is the open volume below.

%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    area_unit: sqft
  }

  floor GroundFloor {
    room Vestibule at (0,0) size (6 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] label "Entry"
    room Kitchen at (6,0) size (10 x 8) walls [top: window, right: solid, bottom: solid, left: solid] label "Kitchen"
    room Bath at (16,0) size (8 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] label "Bath"
    room SleepingArea at (0,8) size (24 x 12) walls [top: solid, right: window, bottom: window, left: solid] label "Sleeping / Living"
  }

  # Front door enters the vestibule from outside (top wall).
  connect Vestibule.top to outside door at 50%

  # Vestibule opens into the main living/sleeping volume.
  connect Vestibule.bottom to SleepingArea.top door at 13%

  # Wide kitchen pass-through to the open sleeping/living area.
  connect Kitchen.bottom to SleepingArea.top opening at 46% size (6ft x full)

  # Bath accessed from the sleeping/living area, away from the entry.
  connect Bath.bottom to SleepingArea.top door at 83%
