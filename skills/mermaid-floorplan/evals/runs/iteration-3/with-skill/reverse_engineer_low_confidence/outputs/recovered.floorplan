# BlurryStudio
# Generated by program_to_skeleton.mjs (rows strategy).
# Edit with modify.mjs or by hand; rerun validate.mjs + design_critic.mjs.

%%{version: 1.0}%%
floorplan

  floor GroundFloor {
    room Kitchen at (0,0) size (10 x 10) walls [top: window, right: solid, bottom: solid, left: solid] label "Kitchen"
    room Bath at (4,10) size (6 x 6) walls [top: solid, right: solid, bottom: solid, left: solid] label "Bath"
    room LivingArea at (10,0) size (12 x 20) walls [top: window, right: solid, bottom: solid, left: solid] label "Living / Sleep"
  }

  connect LivingArea.bottom to outside door at 35%
  connect Kitchen.right to LivingArea.left door at 25%
  connect Bath.right to LivingArea.left door at 75%
