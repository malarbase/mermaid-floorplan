%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    area_unit: sqft
  }

  floor GroundFloor {
    room Foyer at (0,0) size (8 x 12) walls [top: solid, right: solid, bottom: solid, left: solid] label "Foyer"
    room Living at (8,0) size (16 x 12) walls [top: window, right: solid, bottom: solid, left: solid] label "Living"
    room Dining at (24,0) size (12 x 12) walls [top: window, right: solid, bottom: solid, left: solid] label "Dining"
    room Kitchen at (36,0) size (14 x 12) walls [top: window, right: solid, bottom: solid, left: solid] label "Kitchen"
    room Hall at (0,12) size (50 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] label "Hall"
    room Bedroom2 at (0,16) size (12 x 16) walls [top: solid, right: solid, bottom: window, left: window] label "Bedroom 2"
    room Bath2 at (12,16) size (8 x 16) walls [top: solid, right: solid, bottom: solid, left: solid] label "Hall Bath"
    room Bedroom3 at (20,16) size (12 x 16) walls [top: solid, right: solid, bottom: window, left: solid] label "Bedroom 3"
    room Master at (32,16) size (12 x 16) walls [top: solid, right: solid, bottom: window, left: solid] label "Master"
    room MasterBath at (44,16) size (6 x 16) walls [top: solid, right: solid, bottom: solid, left: solid] label "Ensuite"
  }

  connect Foyer.bottom to Hall.top door at 50%
  connect Living.bottom to Hall.top door at 25%
  connect Dining.bottom to Hall.top door at 65%
  connect Kitchen.bottom to Hall.top door at 90%
  connect Hall.bottom to Bedroom2.top door at 10%
  connect Hall.bottom to Bath2.top door at 32%
  connect Hall.bottom to Bedroom3.top door at 52%
  connect Hall.bottom to Master.top door at 78%
  connect Master.right to MasterBath.left door at 15%
  connect Hall.left to outside door at 50%
