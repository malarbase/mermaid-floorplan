# Fixture: every room uses absolute `at (x, y)` positioning.
# Use as input for the convert_to_relative eval.

%%{version: 1.0}%%
floorplan

  floor GroundFloor {
    room Foyer       at (0, 0)   size (6 x 10) walls [top: solid, right: solid, bottom: solid, left: solid] label "Entry"
    room LivingRoom  at (6, 0)   size (16 x 10) walls [top: window, right: solid, bottom: solid, left: solid] label "Living"
    room Kitchen     at (22, 0)  size (12 x 10) walls [top: window, right: solid, bottom: solid, left: solid] label "Kitchen"
    room Hall        at (0, 10)  size (34 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] label "Hall"
    room Bedroom     at (0, 14)  size (12 x 12) walls [top: solid, right: solid, bottom: window, left: window] label "Bedroom"
    room Bath        at (12, 14) size (6 x 12) walls [top: solid, right: solid, bottom: window, left: solid] label "Bath"
    room Office      at (18, 14) size (16 x 12) walls [top: solid, right: window, bottom: window, left: solid] label "Office"
  }

  connect Foyer.top to outside door at 50%
  connect Foyer.right to LivingRoom.left opening at 50% size (5ft x full)
  connect LivingRoom.right to Kitchen.left opening at 50% size (5ft x full)
  connect Foyer.bottom to Hall.top door at 50%
  connect Hall.bottom to Bedroom.top door at 20%
  connect Hall.bottom to Bath.top door at 50%
  connect Hall.bottom to Office.top door at 80%
