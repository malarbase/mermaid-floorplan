# Fixture: every room uses absolute `at (x, y)` positioning.
# Use as input for the convert_to_relative eval.

%%{version: 1.0}%%
floorplan

  floor GroundFloor {
    room Foyer       at (0, 0)   size (6 x 10) walls [top: solid, right: solid, bottom: solid, left: solid] label "Entry"
    room LivingRoom  size (16 x 10) walls [top: window, right: solid, bottom: solid, left: solid] right-of Foyer label "Living"
    room Kitchen     size (12 x 10) walls [top: window, right: solid, bottom: solid, left: solid] right-of LivingRoom label "Kitchen"
    room Hall        size (34 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] below Kitchen align right label "Hall"
    room Bedroom     size (12 x 12) walls [top: solid, right: solid, bottom: window, left: window] below Hall label "Bedroom"
    room Bath        size (6 x 12) walls [top: solid, right: solid, bottom: window, left: solid] right-of Bedroom label "Bath"
    room Office      size (16 x 12) walls [top: solid, right: window, bottom: window, left: solid] below Hall align right label "Office"
  }

  connect Foyer.top to outside door at 50%
  connect Foyer.right to LivingRoom.left opening at 50% size (5ft x full)
  connect LivingRoom.right to Kitchen.left opening at 50% size (5ft x full)
  connect Foyer.bottom to Hall.top door at 50%
  connect Hall.bottom to Bedroom.top door at 20%
  connect Hall.bottom to Bath.top door at 50%
  connect Hall.bottom to Office.top door at 80%
