%%{version: 1.0}%%
# Variation 3 — CENTRAL CORRIDOR
# 2BR test brief, ~1000 sqft, central horizontal corridor.
# Public block on the north (Foyer + Living + Kitchen).
# Hall runs east-west across the middle, double-loaded.
# Private block on the south (Bedroom2 + baths + Master).
# Bathrooms stack vertically and share a horizontal wet wall at y=22.
# Every bedroom has an exterior window.
floorplan
  config { default_unit: ft }

  floor Main {
    # Public (north)
    room Foyer         at (0, 0)   size (8 x 12)  walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Foyer"
    room LivingRoom    at (8, 0)   size (16 x 12) walls [top: window, right: solid, bottom: solid, left: solid]  label "Living Room"
    room Kitchen       at (24, 0)  size (14 x 12) walls [top: window, right: solid, bottom: solid, left: solid]  label "Kitchen"

    # Central east-west corridor
    room Hall          at (0, 12)  size (38 x 4)  walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Hall"

    # Private (south)
    room Bedroom2      at (0, 16)  size (12 x 12) walls [top: solid,  right: solid, bottom: window, left: solid] label "Bedroom 2"
    room HallBath      at (12, 16) size (6 x 6)   walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Hall Bath"
    room MasterBath    at (12, 22) size (6 x 6)   walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Ensuite"
    room MasterBedroom at (18, 16) size (20 x 12) walls [top: solid,  right: window, bottom: window, left: solid] label "Master"
  }

  # Entry from outside via Foyer's north wall
  connect Foyer.top to outside door at 50%

  # Public flow north of the corridor
  connect Foyer.right      to LivingRoom.left opening at 50%
  connect LivingRoom.right to Kitchen.left    opening at 50%

  # North side of the central hall (public-to-corridor)
  connect Foyer.bottom      to Hall.top door    at 10%
  connect LivingRoom.bottom to Hall.top opening at 50%
  connect Kitchen.bottom    to Hall.top opening at 85%

  # South side of the central hall (corridor-to-private)
  connect Hall.bottom to Bedroom2.top      door at 15%
  connect Hall.bottom to HallBath.top      door at 40%
  connect Hall.bottom to MasterBedroom.top door at 75%

  # Ensuite door from MasterBath into MasterBedroom (east wall of bath)
  connect MasterBath.right to MasterBedroom.left door at 50%
