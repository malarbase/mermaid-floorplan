%%{version: 1.0}%%
# Variation 2 — L-SHAPE
# 2BR test brief, ~1000 sqft, L-shaped (Γ) plan.
# Public arm (Foyer + Living + Kitchen) runs east-west across the top.
# Private arm extends south from below the Kitchen with a vertical hall.
# Both bathrooms cluster in the middle and share a wet wall at x=38.
# Every bedroom has an exterior window.
floorplan
  config { default_unit: ft }

  floor Main {
    # Public east-west arm (north)
    room Foyer         at (0, 0)   size (10 x 10) walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Foyer"
    room LivingRoom    at (10, 0)  size (18 x 14) walls [top: window, right: solid, bottom: solid, left: solid]  label "Living Room"
    room Kitchen       at (28, 0)  size (12 x 14) walls [top: window, right: solid, bottom: solid, left: solid]  label "Kitchen"

    # Vertical hall feeds the southern private arm
    room Hall          at (28, 14) size (4 x 28)  walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Hall"

    # Private arm (south, east of hall)
    room Bedroom2      at (32, 14) size (12 x 12) walls [top: solid,  right: window, bottom: solid, left: solid] label "Bedroom 2"
    room HallBath      at (32, 26) size (6 x 6)   walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Hall Bath"
    room MasterBath    at (38, 26) size (6 x 6)   walls [top: solid,  right: solid, bottom: solid, left: solid]  label "Ensuite"
    room MasterBedroom at (32, 32) size (14 x 10) walls [top: solid,  right: window, bottom: window, left: solid] label "Master"
  }

  # Entry from outside via Foyer's north wall
  connect Foyer.top to outside door at 50%

  # Public flow (open between living spaces)
  connect Foyer.right       to LivingRoom.left opening at 50%
  connect LivingRoom.right  to Kitchen.left    opening at 50%

  # Public-to-private transition: kitchen drops into the hall
  connect Kitchen.bottom to Hall.top door at 50%

  # Hall serves the private arm from its east wall
  connect Hall.right to Bedroom2.left      door at 20%
  connect Hall.right to HallBath.left      door at 50%
  connect Hall.right to MasterBedroom.left door at 85%

  # Ensuite door from MasterBath into MasterBedroom (north wall of master)
  connect MasterBath.bottom to MasterBedroom.top door at 50%
