%%{version: 1.0}%%
floorplan
  config { wall_thickness: 0.25 }

  floor Studio {
    # Sleeping area – 12 x 10 = 120 sqft (top-left)
    room Sleeping at (0, 0) size (12 x 10) walls [top: window, right: solid, bottom: solid, left: solid] label "Sleeping Area"

    # Bathroom – 12 x 6 = 72 sqft (top-right). Door routed off Sleeping.
    # Bathroom does NOT share any wall with Kitchen (placed in opposite corners).
    room Bathroom at (12, 0) size (12 x 6) walls [top: solid, right: solid, bottom: solid, left: solid] label "Bathroom"

    # Kitchen – 12 x 10 = 120 sqft (bottom-left). Open-plan with Living/Entry.
    room Kitchen at (0, 10) size (12 x 10) walls [top: solid, right: open, bottom: window, left: window] label "Kitchen"

    # Living/Entry – 12 x 14 = 168 sqft (right side). Open-plan with Kitchen.
    # Front door enters here so the entry is part of the open public zone.
    room LivingEntry at (12, 6) size (12 x 14) walls [top: solid, right: window, bottom: solid, left: open] label "Living / Entry"
  }

  # Bathroom door opens onto the Sleeping area (NOT entry/foyer/outside).
  connect Sleeping.right to Bathroom.left door at 30%

  # Sleeping area opens into the open public zone (no hallway needed).
  connect Sleeping.bottom to Kitchen.top door at 75%

  # Front door enters into the Living/Entry (open public zone).
  connect LivingEntry.bottom to outside door at 50%
