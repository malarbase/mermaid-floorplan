# 3-bedroom single-floor suburban house, ~1800 sqft.
# Layout: public rooms in front (Living, Foyer, Dining, Kitchen),
# central east-west hallway, three bedrooms + hall bath in back.
# Master bedroom has its own ensuite. All bedrooms accessible via the hallway.

%%{version: 1.0}%%
floorplan
  config { default_unit: ft }


  floor MainFloor {
    # ----- Front (public) row -----
    room LivingRoom at (0, 0) size (22 x 18)
      walls [top: window, right: solid, bottom: solid, left: window]
      label "Living Room"

    room Foyer at (22, 0) size (8 x 18)
      walls [top: door, right: solid, bottom: solid, left: solid]
      label "Foyer"

    room DiningRoom at (30, 0) size (16 x 10)
      walls [top: window, right: window, bottom: solid, left: solid]
      label "Dining Room"

    room Kitchen at (30, 10) size (16 x 8)
      walls [top: solid, right: window, bottom: solid, left: solid]
      label "Kitchen"

    # ----- Central hallway (connects all bedrooms) -----
    room Hallway at (4, 18) size (42 x 4)
      walls [top: solid, right: solid, bottom: solid, left: solid]
      label "Hallway"

    # ----- Bedrooms / bath (back of house) -----
    room Bedroom3 at (0, 22) size (14 x 14)
      walls [top: solid, right: solid, bottom: window, left: window]
      label "Bedroom 3"

    room HallBath at (14, 22) size (10 x 10)
      walls [top: solid, right: solid, bottom: solid, left: solid]
      label "Hall Bath"

    room Bedroom2 at (24, 22) size (12 x 14)
      walls [top: solid, right: solid, bottom: window, left: solid]
      label "Bedroom 2"

    room MasterBedroom at (36, 22) size (14 x 16)
      walls [top: solid, right: solid, bottom: window, left: solid]
      label "Master Bedroom"

    room Ensuite at (50, 22) size (8 x 10)
      walls [top: solid, right: window, bottom: solid, left: solid]
      label "Ensuite"
  }

  # ----- Connections -----
  # Front entry
  connect Foyer.top to outside door at 50%

  # Public-room circulation
  connect Foyer.left to LivingRoom.right door at 50%
  connect Foyer.right to DiningRoom.left door at 50%
  connect DiningRoom.bottom to Kitchen.top door at 50%

  # Foyer into the hallway
  connect Foyer.bottom to Hallway.top door at 50%

  # Hallway to all three bedrooms and the hall bath
  connect Hallway.bottom to Bedroom3.top door at 15%
  connect Hallway.bottom to HallBath.top door at 40%
  connect Hallway.bottom to Bedroom2.top door at 65%
  connect Hallway.bottom to MasterBedroom.top door at 90%

  # Master suite: ensuite off the master bedroom
  connect MasterBedroom.right to Ensuite.left door at 50%
