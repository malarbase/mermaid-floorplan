%%{version: 1.0}%%
floorplan
  config { wall_thickness: 0.25 }

  floor Main {
    room Kitchen at (0,0) size (10 x 10) walls [top: solid, right: window, bottom: solid, left: solid] label "Kitchen"
    room Bath size (10 x 10) walls [top: solid, right: solid, bottom: solid, left: window] below Kitchen label "Bath"
    room LivingArea size (12 x 20) walls [top: window, right: window, bottom: window, left: solid] right-of Kitchen label "Living / Sleep"
  }

  connect Bath.right to LivingArea.left door at 50%
