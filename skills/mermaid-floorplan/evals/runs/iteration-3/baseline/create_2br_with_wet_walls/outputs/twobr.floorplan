%%{version: 1.0}%%
# 1000 sqft 2-bedroom apartment
# Total area: 1024 sqft
# - LivingRoom: 18 x 12 = 216 sqft
# - Kitchen:    14 x 12 = 168 sqft
# - Hallway:    18 x 4  =  72 sqft
# - Bathroom:   14 x 4  =  56 sqft  (shares plumbing wall with Kitchen above)
# - MasterBed:  16 x 16 = 256 sqft  (window on bottom and left)
# - Bedroom2:   16 x 16 = 256 sqft  (window on bottom and right)
floorplan

  floor MainFloor {
    room LivingRoom at (0,0) size (18 x 12) walls [top: window, right: solid, bottom: solid, left: solid] label "Living Room"

    room Kitchen size (14 x 12) walls [top: window, right: solid, bottom: solid, left: solid] right-of LivingRoom label "Kitchen"

    room Hallway size (18 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] below LivingRoom label "Hallway"

    # Bathroom sits directly below Kitchen so Kitchen's bottom wall and
    # Bathroom's top wall are the SAME shared wall = plumbing wall.
    room Bathroom size (14 x 4) walls [top: solid, right: solid, bottom: solid, left: solid] right-of Hallway label "Bathroom"

    room MasterBedroom size (16 x 16) walls [top: solid, right: solid, bottom: window, left: window] below Hallway label "Master Bedroom"

    room Bedroom2 size (16 x 16) walls [top: solid, right: window, bottom: window, left: solid] right-of MasterBedroom label "Bedroom 2"
  }

  connect LivingRoom.right to Kitchen.left door at 50%
  connect LivingRoom.bottom to Hallway.top door at 25%
  connect Hallway.right to Bathroom.left door at 50%
  connect Hallway.bottom to MasterBedroom.top door at 25%
  connect MasterBedroom.right to Bedroom2.left door at 50%
