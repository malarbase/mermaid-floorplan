# 480 sqft Studio Apartment
# Total floor area:
#   Sleeping/Living : 24 x 15 = 360 sqft
#   Vestibule       :  4 x  5 =  20 sqft
#   Bathroom        :  5 x  5 =  25 sqft
#   Kitchen         : 15 x  5 =  75 sqft
#   ------------------------------------
#   Total                    = 480 sqft

%%{version: 1.0}%%
floorplan

  config { default_unit: ft, wall_thickness: 0.5 }

  floor Studio {
    # Main open sleeping / living area
    room Sleeping at (0,0) size (24 x 15) walls [top: solid, right: window, bottom: window, left: window] label "Sleeping / Living"

    # Entry vestibule sits above the living area, top-left
    room Vestibule size (4 x 5) walls [top: door, right: solid, bottom: open, left: solid] above Sleeping align left label "Entry"

    # Bathroom adjacent to the vestibule
    room Bathroom size (5 x 5) walls [top: solid, right: solid, bottom: solid, left: solid] right-of Vestibule label "Bath"

    # Kitchen forms the rest of the top strip, opens onto the living area
    room Kitchen size (15 x 5) walls [top: window, right: solid, bottom: open, left: solid] right-of Bathroom label "Kitchen"
  }

  # Doorways and external entry
  connect Vestibule.top to outside door at 50%
  connect Vestibule.bottom to Sleeping.top door at 50%
  connect Vestibule.right to Bathroom.left door at 50%
  connect Kitchen.bottom to Sleeping.top door at 70%
