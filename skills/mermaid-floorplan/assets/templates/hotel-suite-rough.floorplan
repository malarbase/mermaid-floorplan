# Template: Hotel Suite - ROUGH variant
#
# Intentionally flawed hotel suite that demonstrates common LLM mistakes:
#   1. Bath opens directly into the bedroom with no buffer (privacy
#      violation in a multi-occupant suite).
#   2. Bedroom has no exterior window.
#   3. The vestibule is a one-room dead-end (corridor door enters but
#      nothing else connects).
#   4. Lounge has no door to anything except the bedroom (forced walk-
#      through).

%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    area_unit: sqft
  }

  floor GuestFloor {
    # Vestibule isolated from the rest of the suite.
    room Vestibule at (0,0) size (5 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] label "Entry"

    # Bath right next to bedroom door, no closet/buffer.
    room Bath size (8 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] right-of Vestibule align top label "Bath"

    # Closet far from the entry — guest dumps luggage in the wrong room.
    room Closet size (5 x 8) walls [top: solid, right: solid, bottom: solid, left: solid] right-of Bath align top label "Closet"

    # Bedroom: no window at all.
    room Bedroom size (18 x 10) walls [top: solid, right: solid, bottom: solid, left: solid] below Vestibule align left label "Bedroom"

    # Lounge buried at the back; only reachable by walking through bedroom.
    room Lounge size (18 x 8) walls [top: solid, right: solid, bottom: window, left: solid] below Bedroom align left label "Lounge"
  }

  # Suite door from corridor (Vestibule is otherwise a dead-end).
  connect Vestibule.top to outside door at 50%

  # Bath opens directly into bedroom (privacy violation).
  connect Bath.bottom to Bedroom.top door at 30%

  # Closet only reachable via bath -> bedroom -> lounge chain.
  connect Closet.bottom to Bedroom.top door at 80%

  # Bedroom -> Lounge (open wall = forced walk-through).
  connect Bedroom.bottom to Lounge.top opening at 50% size (6ft x full)
