# Template: Studio Apartment - ROUGH variant
#
# Intentionally flawed studio that demonstrates common LLM mistakes:
#   1. Bath opens directly into the LivingArea (privacy violation).
#   2. Wet rooms (Kitchen, Bath) do not share any walls (long plumbing).
#   3. Kitchen has only solid walls -> no daylight at all.
#   4. The front door is on a wall that has no obvious circulation path.
#
# Use this template as a "before" state for design_critic /
# suggest_improvements demos. The output should be valid DSL but produce
# multiple soft critic warnings.

%%{version: 1.0}%%
floorplan

  config {
    default_unit: ft,
    area_unit: sqft
  }

  floor GroundFloor {
    # Bath in the upper-left, isolated from kitchen plumbing.
    room Bath at (0,0) size (8 x 8) walls [top: solid, right: solid, bottom: solid, left: window] label "Bath"

    # LivingArea adjacent to bath - bathroom door opens straight into living.
    room LivingArea size (14 x 8) walls [top: window, right: window, bottom: solid, left: solid] right-of Bath align top label "Living"

    # Kitchen tucked under the LivingArea - far from the bath, no exterior wall.
    room Kitchen size (14 x 12) walls [top: solid, right: solid, bottom: solid, left: solid] below LivingArea align left label "Kitchen"

    # Awkward leftover storage strip along the bottom of the bath wall.
    room Storage size (8 x 12) walls [top: solid, right: solid, bottom: solid, left: solid] below Bath align left label "Storage"
  }

  # Front door in a corner with no circulation backbone.
  connect Storage.bottom to outside door at 50%

  # Bath -> Living (privacy violation).
  connect Bath.right to LivingArea.left door at 50%

  # Living -> Kitchen.
  connect LivingArea.bottom to Kitchen.top door at 50%

  # Living -> Storage chain.
  connect Storage.top to Bath.bottom door at 50%
  connect Storage.right to Kitchen.left door at 50%
